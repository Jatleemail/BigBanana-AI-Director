# API Key for Anthropic/Gemini
ANTSK_API_KEY=your_api_key_here
# Frontend media proxy endpoint (same-origin backend)
VITE_MEDIA_PROXY_ENDPOINT=/api/media-proxy
VITE_MEDIA_PROXY_ENABLED=true

# new-api account center endpoint
VITE_NEW_API_ENDPOINT=https://api.antsk.cn

# 腾讯云 COS 配置（声音克隆上传用）
# 注意：COS 配置已改为运行时配置，通过模型配置页面"腾讯云COS"选项卡设置
# 以下环境变量仅作为本地开发时的回退默认值
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=ap-beijing
TENCENT_COS_BUCKET=
TENCENT_COS_CDN_DOMAIN=
